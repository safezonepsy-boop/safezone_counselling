        function renderDaftarMateri() {
            const materiContainer = document.getElementById('materi-container');
            materiContainer.innerHTML = ''; 
            let allCompleted = true;

            daftarMateri.forEach(materi => {
                const isDone = userProgress[materi.id];
                if (!isDone) allCompleted = false;

                const checkBadge = isDone ? `<span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full font-bold shadow-sm inline-flex items-center gap-1 mt-2 md:mt-0">✅ SELESAI</span>` : '';
                const btnText = isDone ? "Baca Ulang Modul &rarr;" : "Pelajari Modul Ini &rarr;";
                const btnColor = isDone ? "bg-gray-200 text-gray-700" : "bg-brand-teal text-white";

                const articleHTML = `
                    <article class="flex flex-col lg:flex-row gap-6 lg:gap-10 items-center bg-white border ${isDone ? 'border-green-300 bg-green-50/10' : 'border-gray-100'} p-6 md:p-8 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 relative z-10">
                        <div class="flex-1 w-full text-center lg:text-left">
                            <div class="flex flex-col md:flex-row md:items-center gap-2 mb-2 justify-center lg:justify-start">
                                <p class="text-xs font-bold tracking-widest text-pink-500 uppercase">in ${materi.kategori}</p>${checkBadge}
                            </div>
                            <h3 class="text-2xl md:text-3xl font-extrabold text-brand-pink mb-4">${materi.judul}</h3>
                            <p class="text-gray-600 mb-6 text-sm md:text-base">${materi.kutipan}</p>
                            <button onclick="window.bukaMateri('${materi.id}')" class="inline-block ${btnColor} px-8 py-3 rounded-full font-bold transition shadow-md w-full sm:w-auto relative z-20 cursor-pointer text-sm">${btnText}</button>
                        </div>
                        <div class="w-full lg:w-2/5 mt-6 lg:mt-0 relative z-20 cursor-pointer rounded-[2rem] overflow-hidden shadow-md border-4 border-white group" onclick="window.bukaMateri('${materi.id}')">
                            <img id="thumb-${materi.id}" src="${materi.gambar}" alt="${materi.judul}" class="w-full h-48 lg:h-64 object-cover group-hover:scale-105 transition transform duration-300">
                        </div>
                    </article>
                `;
                materiContainer.innerHTML += articleHTML;

                const navLink = document.getElementById('nav-' + materi.id);
                if(navLink) navLink.innerHTML = `${isDone ? '✅ ' : ''} ${materi.id === 'pemahaman-diri' ? '1' : materi.id === 'penerimaan-diri' ? '2' : materi.id === 'harga-diri' ? '3' : '4'}. ${materi.judul.split(' (')[0]}`;
            });

            if (allCompleted && currentUser) {
                document.getElementById('banner-completion').classList.remove('hidden');
                document.getElementById('nav-sertifikat').classList.remove('hidden');
            }
        }

        function updateUIWithUser() {
            if(!currentUser) return;
            document.getElementById('user-display-name').innerText = currentUser.nama.split(' ')[0];
            document.getElementById('welcome-name').innerText = currentUser.nama.split(' ')[0] + "!";
            document.querySelectorAll('.nama-siswa-dinamis').forEach(el => el.innerText = currentUser.nama);
            
            const certInfo = document.getElementById('cert-sekolah-kelas');
            if(certInfo) certInfo.innerText = `${currentUser.kelas} - ${currentUser.sekolah}`;

            document.getElementById('main-nav').classList.remove('hidden');
            document.getElementById('main-header').classList.remove('hidden');
            document.getElementById('main-footer').classList.remove('hidden');
            document.getElementById('main-nav').classList.add('flex');
            
            renderDaftarMateri();
        }

        // Init App Saat Load
        function initApp() {
            window.renderAngket(); 
            const savedUser = localStorage.getItem('safezone_user');
            const savedProgress = localStorage.getItem('safezone_progress');
            
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                if(savedProgress) userProgress = JSON.parse(savedProgress);
                updateUIWithUser();
                switchTab('beranda');
            } else {
                switchTab('register'); 
            }
        }
        
        window.onload = initApp; 

    </script>

    <!-- FIREBASE MODULE -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'safezone-app';
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        let userObj = null;

        // Override the local placeholder functions to save to Cloud
        window.dbSaveAktivitas = async function(data) {
            if (!userObj) return;
            try {
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'student_activities'), data);
            } catch(e) { console.error(e); }
        };

        window.dbSaveAngket = async function(data) {
            if (!userObj) return;
            try {
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'angket_results'), data);
            } catch(e) { console.error(e); }
        };

        // Load Admin Data when Firebase is ready and Panel is open
        window.loadAdminDataFromDB = function() {
            if (!userObj) return;
            
            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'angket_results'), (snapshot) => {
                let data = [];
                snapshot.forEach(doc => data.push(doc.data()));
                data.sort((a,b) => b.timestamp - a.timestamp);
                
                dataAngketTersimpan = data; 
                document.getElementById('admin-angket-count').innerText = data.length + " Siswa Mengisi";
                
                let tBody = '';
                data.forEach((d, idx) => {
                    const date = new Date(d.timestamp).toLocaleString('id-ID', {day:'numeric', month:'short', hour:'2-digit', minute:'2-digit'});
                    const btnDetail = d.itemDetails ? `<button onclick="window.tampilkanDetailSkor(${idx})" class="text-xs bg-teal-500 hover:bg-teal-600 text-white px-2 py-1 rounded transition">Lihat Skor</button>` : `<span class="text-xs text-gray-400">-</span>`;
                    tBody += `
                        <tr class="border-b hover:bg-gray-50 transition">
                            <td class="p-3 text-xs text-gray-500">${date}</td>
                            <td class="p-3 font-bold text-teal-800">${d.nama}</td>
                            <td class="p-3 text-xs">${d.kelas} <br> ${d.sekolah}</td>
                            <td class="p-3 text-center font-extrabold text-lg">${d.totalScore}</td>
                            <td class="p-3 text-center"><span class="bg-gray-200 px-2 py-1 rounded text-xs font-bold">${d.status}</span></td>
                            <td class="p-3 text-xs text-pink-600 font-bold">${d.dimensiTerendah || '-'}</td>
                            <td class="p-3 text-center">${btnDetail}</td>
                        </tr>
                    `;
                });
                document.getElementById('admin-table-angket').innerHTML = tBody || `<tr><td colspan="7" class="p-6 text-center text-gray-400">Belum ada data masuk.</td></tr>`;
            }, (error) => console.error("Error fetching angket:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'student_activities'), (snapshot) => {
                let data = [];
                snapshot.forEach(doc => data.push(doc.data()));
                data.sort((a,b) => b.timestamp - a.timestamp);
                
                document.getElementById('admin-activity-count').innerText = data.length + " Log Terekam";
                let tBody = '';
                data.forEach(d => {
                    const date = new Date(d.timestamp).toLocaleString('id-ID', {day:'numeric', month:'short', hour:'2-digit', minute:'2-digit'});
                    tBody += `
                        <tr class="border-b hover:bg-gray-50 transition">
                            <td class="p-3 text-xs text-gray-500">${date}</td>
                            <td class="p-3 font-bold text-teal-800">${d.nama} <br><span class="text-xs text-gray-400 font-normal">${d.kelas}</span></td>
                            <td class="p-3"><span class="text-xs font-bold text-pink-500 bg-pink-50 px-2 py-1 rounded block mb-1">${d.modul}</span><span class="text-xs text-gray-600 font-bold border border-gray-300 rounded px-1">${d.latihan}</span></td>
                            <td class="p-3 text-sm text-gray-700 italic border-l border-gray-100">"${d.jawaban}"</td>
                        </tr>
                    `;
                });
                document.getElementById('admin-table-aktivitas').innerHTML = tBody || `<tr><td colspan="4" class="p-6 text-center text-gray-400">Belum ada data masuk.</td></tr>`;
            }, (error) => console.error("Error fetching aktivitas:", error));
        };

        const initAuth = async () => {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch(e) { console.error("Auth error:", e); }
        };

        initAuth();

        onAuthStateChanged(auth, (u) => {
            userObj = u;
            if(u && !document.getElementById('view-admin-dashboard').classList.contains('hidden')) {
                window.loadAdminDataFromDB();
            }
        });
    </script>
