        function tampilkanDetailSkor(index) {
            const data = dataAngketTersimpan[index];
            if(!data || !data.itemDetails) {
                alert('Data detail tidak tersedia untuk entri lama ini.');
                return;
            }
            
            let htmlContent = `
                <div class="mb-4 bg-gray-100 p-4 rounded-xl">
                    <p class="font-bold text-gray-800">${data.nama} <span class="font-normal text-sm text-gray-600">(${data.kelas})</span></p>
                    <p class="text-sm text-gray-600">Total Skor: <strong class="text-teal-700">${data.totalScore}</strong> (${data.status})</p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm text-center">
                    <div class="font-bold bg-teal-100 p-2 rounded">Soal</div>
                    <div class="font-bold bg-teal-100 p-2 rounded">Jawaban</div>
                    <div class="font-bold bg-teal-100 p-2 rounded">Skor</div>
            `;
            
            for(let i=1; i<=30; i++) {
                const item = data.itemDetails[`q${i}`];
                if(item) {
                    htmlContent += `
                        <div class="border-b p-2 font-mono">Q${i} <span class="text-[10px] text-gray-400">(${item.tipe})</span></div>
                        <div class="border-b p-2 text-gray-600">${item.jawaban}</div>
                        <div class="border-b p-2 font-bold ${item.skor > 2 ? 'text-green-600' : 'text-red-500'}">${item.skor}</div>
                    `;
                }
            }
            htmlContent += `</div>`;
            
            document.getElementById('modal-content-skor').innerHTML = htmlContent;
            document.getElementById('modal-detail-skor').classList.remove('hidden');
        }

        function exportAngketToCSV() {
            if(!dataAngketTersimpan || dataAngketTersimpan.length === 0) {
                alert("Belum ada data untuk diunduh.");
                return;
            }

            let csvContent = "Waktu,Nama Siswa,Email,Kelas,Sekolah,Skor Total,Kategori,Skor Dimensi 1,Skor Dimensi 2,Skor Dimensi 3,Skor Dimensi 4,Dimensi Terendah";
            for(let i=1; i<=30; i++) csvContent += `,Q${i}_Jawaban Mentah,Q${i}_Skor Konversi`;
            csvContent += "\n";

            dataAngketTersimpan.forEach(d => {
                const date = new Date(d.timestamp).toLocaleString('id-ID').replace(/,/g, '');
                const escapeCSV = (str) => `"${(str || '').toString().replace(/"/g, '""')}"`;
                let row = `${escapeCSV(date)},${escapeCSV(d.nama)},${escapeCSV(d.email)},${escapeCSV(d.kelas)},${escapeCSV(d.sekolah)},${d.totalScore},${escapeCSV(d.status)},${d.dimensi1 || 0},${d.dimensi2 || 0},${d.dimensi3 || 0},${d.dimensi4 || 0},${escapeCSV(d.dimensiTerendah)}`;
                
                for(let i=1; i<=30; i++) {
                    if(d.itemDetails && d.itemDetails[`q${i}`]) {
                        row += `,${escapeCSV(d.itemDetails[`q${i}`].jawaban)},${d.itemDetails[`q${i}`].skor}`;
                    } else {
                        row += `,,`;
                    }
                }
                csvContent += row + "\n";
            });

            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", "Data_Analisis_Angket_Konsep_Diri.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

