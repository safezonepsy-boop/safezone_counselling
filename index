            let totalScore = 0;
            let dimScores = { 'Pemahaman Diri': 0, 'Penerimaan Diri': 0, 'Harga Diri': 0, 'Diri Ideal': 0 };
            let itemDetails = {};

            for(let i=1; i<=30; i++) {
                const answer = formData.get('q' + i);
                if(!answer) return;
                
                let score = 0;
                const type = [3,4,7,8,10,14,16,17,19,21,24,25,27,28,30].includes(i) ? '-' : '+';
                const dim = (i<=8) ? 'Pemahaman Diri' : (i<=14) ? 'Penerimaan Diri' : (i<=22) ? 'Harga Diri' : 'Diri Ideal';

                if(type === '+') { 
                    if(answer === 'SS') score = 4; if(answer === 'S') score = 3; if(answer === 'TS') score = 2; if(answer === 'STS') score = 1;
                } else { 
                    if(answer === 'SS') score = 1; if(answer === 'S') score = 2; if(answer === 'TS') score = 3; if(answer === 'STS') score = 4;
                }
                totalScore += score;
                dimScores[dim] += score;
                
                itemDetails[`q${i}`] = { jawaban: answer, skor: score, tipe: type };
            }

            let status = totalScore >= 96 ? 'Tinggi' : totalScore >= 72 ? 'Sedang' : 'Rendah';
            let color = totalScore >= 96 ? 'text-green-600' : totalScore >= 72 ? 'text-yellow-500' : 'text-red-500';

