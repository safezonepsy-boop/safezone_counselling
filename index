        // --- FUNGSI INTERAKSI MATERI ---
        function interaksiSelesai(btn, pesan, customAlertMsg, activityName) {
            const wadah = btn.parentElement;
            const inputs = wadah.querySelectorAll('input, textarea, select');
            let studentAnswer = "";

            inputs.forEach(input => {
                if(input.type === 'checkbox' || input.type === 'radio') {
                    if(input.checked) studentAnswer += "[V] " + (input.parentElement.innerText.trim() || input.value) + " | ";
                } else {
                    if(input.value) studentAnswer += input.value + " | ";
                }
                input.disabled = true;
                if(input.tagName === 'TEXTAREA' || input.tagName === 'INPUT' || input.tagName === 'SELECT') {
                    input.classList.add('bg-gray-100', 'text-gray-500');
                }
            });
            
            btn.innerText = pesan;
            btn.className = 'mt-4 bg-green-500 text-white px-8 py-3 rounded-full font-bold cursor-default w-full md:w-auto transition shadow-md relative z-20';
            btn.disabled = true;

            // Simpan ke Database
            if (currentUser && studentAnswer !== "") {
                const activityTitle = activityName || (btn.previousElementSibling && btn.previousElementSibling.tagName === 'TEXTAREA' ? 'Refleksi / Jurnal' : 'Latihan Aktivitas');
                const dataActivity = {
                    nama: currentUser.nama, kelas: currentUser.kelas, sekolah: currentUser.sekolah,
                    modul: document.getElementById('detail-judul').innerText, latihan: activityTitle, jawaban: studentAnswer, timestamp: Date.now()
                };
                window.dbSaveAktivitas(dataActivity);
            }
            
